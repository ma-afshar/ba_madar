generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Slider {
  id    Int    @id @default(autoincrement())
  image String
  link  String
}

model Category {
  id       Int       @id @default(autoincrement())
  title    String
  image    String

  products Product[]
}

model Product {
  id         Int      @id @default(autoincrement())
  title      String
  image      String
  price      Int
  discount   Int

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])
}

model Banner {
  id    Int    @id @default(autoincrement())
  image String
  link  String
}

model User {
  id        Int       @id @default(autoincrement())
  phone     String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sessions Session[]
}

model OtpChallenge {
  id        Int       @id @default(autoincrement())
  phone     String
  codeHash  String
  attempts  Int       @default(0)
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([phone, createdAt])
}

model Session {
  id        Int      @id @default(autoincrement())
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
