generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Slider {
  id    Int    @id @default(autoincrement())
  image String
  link  String
}

model Category {
  id       Int       @id @default(autoincrement())
  title    String
  image    String

  products Product[]
}

model Product {
  id         Int      @id @default(autoincrement())
  title      String
  image      String
  price      Int
  discount   Int
  stock      Int      @default(0)
  minStock   Int      @default(10)

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])
  purchaseVoucherItems PurchaseVoucherItem[]
  specialOffer SpecialOffer?
}

model SpecialOffer {
  id         Int       @id @default(autoincrement())
  productId  Int       @unique
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  discount   Int
  label      String    @default("پیشنهاد ویژه")
  active     Boolean   @default(true)
  sortOrder  Int       @default(0)
  startsAt   DateTime?
  endsAt     DateTime?
  salesLimit Int?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([active, sortOrder])
}

model PurchaseVoucher {
  id           Int                   @id @default(autoincrement())
  supplierName String
  invoiceNo    String?
  invoiceFile  String?
  notes        String?
  status       String                @default("draft")
  totalCost    Int
  voucherDate  DateTime
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  items        PurchaseVoucherItem[]

  @@index([status, voucherDate])
  @@index([supplierName])
}

model PurchaseVoucherItem {
  id        Int             @id @default(autoincrement())
  quantity  Int
  unitCost  Int
  productId Int
  product   Product         @relation(fields: [productId], references: [id])
  voucherId Int
  voucher   PurchaseVoucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@index([voucherId])
  @@index([productId])
}

model Expense {
  id          Int      @id @default(autoincrement())
  title       String
  category    String
  amount      Int
  description String?
  expenseDate DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([expenseDate])
  @@index([category])
}

model Banner {
  id    Int    @id @default(autoincrement())
  image String
  link  String
}

model User {
  id        Int       @id @default(autoincrement())
  phone     String    @unique
  firstName String?
  lastName  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sessions Session[]
  orders   Order[]
}

model Order {
  id            Int         @id @default(autoincrement())
  status        String      @default("active")
  totalPrice    Int
  deliveryFee   Int
  paymentMethod String
  address       String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  inventoryReserved Boolean @default(false)
  userId        Int
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items         OrderItem[]

  @@index([userId, createdAt])
  @@index([status])
}

model OrderItem {
  id        Int    @id @default(autoincrement())
  productId Int
  title     String
  image     String
  price     Int
  discount  Int
  quantity  Int
  orderId   Int
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model OtpChallenge {
  id        Int       @id @default(autoincrement())
  phone     String
  codeHash  String
  attempts  Int       @default(0)
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([phone, createdAt])
}

model Session {
  id        Int      @id @default(autoincrement())
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
