generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Slider {
  id    Int    @id @default(autoincrement())
  image String
  link  String
}

model Category {
  id       Int       @id @default(autoincrement())
  title    String
  image    String

  products Product[]
}

model Product {
  id         Int      @id @default(autoincrement())
  title      String
  image      String
  price      Int
  discount   Int

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])
}

model Banner {
  id    Int    @id @default(autoincrement())
  image String
  link  String
}